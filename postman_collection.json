        {
          "name": "2. Create Blog",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('blogId', jsonData.data.blog._id);",
                  "    console.log('✅ Blog created successfully');",
                  "    console.log('Blog ID saved to environment');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "Required - Login first!"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"فهم القانون الجنائي المصري\",\n  \"content\": \"القانون الجنائي في مصر يحكمه في المقام الأول قانون العقوبات لعام 1937. يحدد هذا القانون الجرائم المختلفة والعقوبات المرتبطة بها. من المهم للمحامين والمواطنين فهم الأساسيات...\",\n  \"excerpt\": \"دليل شامل للقانون الجنائي في مصر\",\n  \"category\": \"Criminal Law\",\n  \"tags\": [\"criminal\", \"egypt\", \"law\", \"penal code\"],\n  \"coverImage\": \"https://images.unsplash.com/photo-1589829545856-d10d557cf95f\",\n  \"status\": \"published\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/blogs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "blogs"]
            },
            "description": "Create a new blog post. Authentication required."
          },
          "response": []
        },
        {
          "name": "3. Get Blog by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "description": "Optional - adds user context",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/blogs/{{blogId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "blogs", "{{blogId}}"]
            },
            "description": "Get single blog details and increment view count. Authentication optional."
          },
          "response": []
        },
